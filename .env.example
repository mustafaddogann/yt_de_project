# GCP project that owns the BigQuery datasets and the GCS bucket.
GCP_PROJECT_ID=

# Globally unique GCS bucket name for the raw landing zone.
GCS_LANDING_BUCKET=

# Absolute path to the service-account JSON on your laptop.
# Get this from `gcloud iam service-accounts keys create ...`.
GCP_SA_KEY_PATH=/Users/you/.config/gcp/yt-de-sa.json

# Match your local UID so Airflow can write logs back to ./logs
# (run `id -u` to find yours, default 50000 works for most setups).
AIRFLOW_UID=50000
